# Keeps private environment variables and passwords out of GitHub
.env
.env.*
!.env.example

# CommandBox downloads the local Lucee server into this folder
.server/

# Lucee and CommandBox may create these local files
.cfconfig.json
server-*.json

# Database exports and backups may contain private customer information
*.sql
database-backups/

# Temporary files used while checking PDFs and other assets
tmp/

# macOS creates this file automatically inside folders
.DS_Store
